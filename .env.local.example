VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Google Sheets service account (Phase 2)
# Copy these from the downloaded JSON key file:
#   client_email     -> SHEETS_SERVICE_ACCOUNT_EMAIL
#   private_key      -> SHEETS_SERVICE_ACCOUNT_PRIVATE_KEY
# IMPORTANT: keep the private_key on a single line, with literal \n
# escape sequences (NOT real newlines). The smoke-test script unescapes them.
SHEETS_SERVICE_ACCOUNT_EMAIL=
SHEETS_SERVICE_ACCOUNT_PRIVATE_KEY=

# Smoke-test target (pick one sheet to read from in scripts/smoke-test-sheets.mjs).
# SMOKE_TEST_SHEET_ID is the long string between /d/ and /edit in the sheet URL.
# SMOKE_TEST_RANGE is an A1 range like "2026 LAND!A1:F5".
SMOKE_TEST_SHEET_ID=
SMOKE_TEST_RANGE=

# Source sheet IDs (populated as supervisor shares each with the service account)
SHEET_ID_MARKETING_EXPENSE=
SHEET_ID_BANK_DEPOSIT=
SHEET_ID_CUSTOMER_SUPPORT=
SHEET_ID_REALTOR_MANAGERS_WEEKLY=
